{
  "name": "interviewmaster-react",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "concurrently -k \"npm run start:server\" \"npm run start:client\"",
    "start:client": "webpack serve --mode development",
    "start:server": "node server.mjs",
    "serve": "node server.mjs",
    "build": "cross-env NODE_ENV=production webpack --mode production",
    "test": "vitest run"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0"
  }
}
